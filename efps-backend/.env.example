# App
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/efps_dev
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-to-64-char-random-hex-string
JWT_REFRESH_SECRET=change-me-to-another-64-char-random-hex-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Credential Encryption (AES-256-GCM) - 64 hex chars = 32 bytes
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Internal Sync authentication (at least 32 characters)
INTERNAL_SYNC_SECRET=change-me-to-a-very-long-secret-key-at-least-32-chars
INTERNAL_SYNC_URL=http://localhost:3000/api/internal/sync
START_SYNC_WORKER=false
MOCK_GOVT_PORTAL=true

# OTP / SMS
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=
MSG91_SENDER_ID=EFPSMS
MSG91_TEMPLATE_ID=
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=3

# Security
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MS=900000

# File Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=efps-files

# Monitoring
LOG_LEVEL=info
