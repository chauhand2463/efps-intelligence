{
  "name": "efps-intelligence-backend",
  "version": "1.0.0",
  "description": "eFPS Intelligence - Fair Price Shop Management Backend",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "start:cluster": "pm2-runtime start ecosystem.config.cjs",
    "migrate": "tsx scripts/migrate.ts",
    "seed": "tsx scripts/seed.ts",
    "generate-openapi": "tsx scripts/generate-openapi.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/compress": "^9.0.0",
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.1.0",
    "@fastify/swagger": "^9.0.1",
    "@fastify/swagger-ui": "^5.0.1",
    "argon2": "^0.41.1",
    "bullmq": "^5.12.0",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "pino": "^9.4.0",
    "playwright": "^1.60.0",
    "pm2": "^5.4.2",
    "typescript-eslint": "^8.61.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.6",
    "eslint": "^9.9.0",
    "pino-pretty": "^11.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
